{
    "name": "@steipete/mcp-agentify",
    "version": "0.1.0",
    "description": "AI-powered MCP gateway that routes tasks across backend MCP servers.",
    "main": "dist/cli.js",
    "bin": {
        "mcp-agentify": "./bin/mcp-agentify.cjs"
    },
    "files": [
        "dist/**/*",
        "bin/**/*",
        "README.md",
        "LICENSE"
    ],
    "directories": {
        "doc": "docs",
        "test": "tests"
    },
    "scripts": {
        "clean": "node scripts/clean.mjs",
        "build:server": "tsc -p tsconfig.server.json",
        "build:ui": "cd frontend && parcel build src/index.html --dist-dir ../dist/frontend --public-url ./ --no-cache --no-content-hash --no-source-maps",
        "build": "npm run clean && npm run build:server && npm run build:ui",
        "check:package": "node scripts/check-package.mjs",
        "start": "node dist/cli.js",
        "dev:server": "nodemon --watch src --ext ts,json --exec \"tsx ./src/cli.ts\"",
        "dev:ui": "cd frontend && parcel src/index.html --dist-dir ../dist/frontend --public-url ./ --port 3005 --no-cache",
        "dev": "npm run build:ui && npm run dev:server",
        "lint": "eslint \"src/**/*.ts\" \"frontend/src/**/*.tsx\" \"tests/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" \"frontend/src/**/*.tsx\" \"tests/**/*.ts\" --fix",
        "format": "prettier --write \"src/**/*.ts\" \"frontend/src/**/*.tsx\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"*.json\" \"*.md\"",
        "format:check": "prettier --check \"src/**/*.ts\" \"frontend/src/**/*.tsx\" \"tests/**/*.ts\" \"scripts/**/*.mjs\" \"*.json\" \"*.md\"",
        "pretest": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepack": "npm run build && npm run check:package"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/steipete/mcp-agentify.git"
    },
    "keywords": [
        "mcp",
        "model-context-protocol",
        "gateway",
        "orchestration",
        "openai"
    ],
    "author": "Peter Steinberger",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/steipete/mcp-agentify/issues"
    },
    "homepage": "https://github.com/steipete/mcp-agentify#readme",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "dotenv": "^16.6.1",
        "express": "^4.22.2",
        "openai": "^4.104.0",
        "pino": "^9.14.0",
        "preact": "^10.29.2",
        "ws": "^8.21.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^22.19.20",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.32.1",
        "@typescript-eslint/parser": "^8.32.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "nodemon": "^3.1.14",
        "parcel": "^2.16.4",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.3",
        "tsx": "^4.22.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.61.0",
        "vitest": "^4.1.8"
    }
}
